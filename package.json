{
  "name": "umbra",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,ui \"npm run dev:api\" \"npm run dev:ui\"",
    "dev:api": "node --watch server.mjs --port 3001",
    "dev:watch": "node --watch server.mjs --port 3001",
    "dev:ui": "vite --host localhost --port 3000",
    "dev:react": "npm run dev",
    "dev:legacy": "node server.mjs",
    "start": "node server.mjs",
    "test": "node --test"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "vite": "^8.1.5"
  }
}
